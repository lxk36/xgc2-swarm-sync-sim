<?xml version="1.0"?>
<!-- For visualization of tello -->

<launch>
    <arg name="open_rviz" default="true"/>

    <include file="$(dirname)/ugv_visualizer_single.launch">
        <arg name="ns" value="ugv1"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/ugv_visualizer_single.launch">
        <arg name="ns" value="ugv2"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/ugv_visualizer_single.launch">
        <arg name="ns" value="ugv3"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/ugv_visualizer_single.launch">
        <arg name="ns" value="ugv4"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/ugv_visualizer_single.launch">
        <arg name="ns" value="ugv5"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/ugv_visualizer_single.launch">
        <arg name="ns" value="ugv6"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/ugv_visualizer_single.launch">
        <arg name="ns" value="ugv7"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/ugv_visualizer_single.launch">
        <arg name="ns" value="ugv8"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/ugv_visualizer_single.launch">
        <arg name="ns" value="ugv9"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/ugv_visualizer_single.launch">
        <arg name="ns" value="ugv10"/>
        <arg name="open_rviz" value="false"/>
    </include>

    
    <group if="$(arg open_rviz)">
        <node name="rviz" pkg="rviz" type="rviz" args="-d $(find ugv_sim)/launch/multi_ugv.rviz" required="false" />
    </group>


</launch>

<?xml version="1.0"?>
<!-- For visualization of tello -->

<launch>
    <arg name="open_rviz" default="true"/>

    <include file="$(dirname)/tello_visualizer_single.launch">
        <arg name="ns" value="tello1"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/tello_visualizer_single.launch">
        <arg name="ns" value="tello2"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/tello_visualizer_single.launch">
        <arg name="ns" value="tello3"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/tello_visualizer_single.launch">
        <arg name="ns" value="tello4"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/tello_visualizer_single.launch">
        <arg name="ns" value="tello5"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/tello_visualizer_single.launch">
        <arg name="ns" value="tello6"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/tello_visualizer_single.launch">
        <arg name="ns" value="tello7"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/tello_visualizer_single.launch">
        <arg name="ns" value="tello8"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/tello_visualizer_single.launch">
        <arg name="ns" value="tello9"/>
        <arg name="open_rviz" value="false"/>
    </include>

    <include file="$(dirname)/tello_visualizer_single.launch">
        <arg name="ns" value="tello10"/>
        <arg name="open_rviz" value="false"/>
    </include>
    
    <group if="$(arg open_rviz)">
        <node name="rviz" pkg="rviz" type="rviz" args="-d $(find tello_sim)/launch/multi_tello.rviz" required="false" />
    </group>


</launch>
